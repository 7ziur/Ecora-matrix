<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ECORA MATRIX | Impact & ROI Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;600&family=Noto+Sans+Arabic:wght@300;400;600&display=swap" rel="stylesheet"/>
<style>
/* ════════════════ SCREEN ════════════════ */
:root{
  --bg:#080d0b;--surface:#0e1812;--surface3:#0b1410;
  --accent:#34d87e;--accent2:#6ee9a4;--accent-dim:rgba(52,216,126,.12);
  --warn:#f5c542;--red:#f87171;--blue:#60a5fa;
  --text:#dff5e8;--muted:#5a8068;--muted2:#3d604a;
  --border:#1a2e1f;--border2:#243828;
  --gold:#d4a942;--gold-dim:rgba(212,169,66,.15);
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;font-weight:300;min-height:100vh;overflow-x:hidden}
body[lang="ar"]{font-family:'Noto Sans Arabic','Outfit',sans-serif}
body[lang="ar"] .wrapper{direction:rtl}
body[lang="ar"] h1{font-family:'Noto Sans Arabic',serif;font-size:clamp(1.7rem,4vw,2.8rem);line-height:1.35}
body[lang="ar"] .field label,body[lang="ar"] .card-title,body[lang="ar"] .result-label,
body[lang="ar"] .result-sub,body[lang="ar"] .breakdown-title,body[lang="ar"] .breakdown-row .lbl,
body[lang="ar"] .bar-label,body[lang="ar"] .bar-meta span,body[lang="ar"] .subtitle,
body[lang="ar"] .ctrl-label,body[lang="ar"] .footer-itex span,body[lang="ar"] .footer-bottom span
{font-family:'Noto Sans Arabic',sans-serif}
body[lang="ar"] .breakdown-row{flex-direction:row-reverse}
body[lang="ar"] .bar-meta{flex-direction:row-reverse}
body[lang="ar"] .btn-row{justify-content:flex-end}
body[lang="ar"] .controls-bar,.site-header{flex-direction:row-reverse}
body[lang="ar"] .logo-area{flex-direction:row-reverse}
body[lang="ar"] .logo-text{text-align:right}
body[lang="ar"] .result-label,.result-sub{text-align:right}
body[lang="ar"] .card-title,.breakdown-title,.bar-label{text-align:right;letter-spacing:0}
body::before{content:'';position:fixed;top:-300px;left:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(52,216,126,.055) 0%,transparent 70%);pointer-events:none;z-index:0}
body::after{content:'';position:fixed;bottom:-200px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(52,216,126,.03) 0%,transparent 70%);pointer-events:none;z-index:0}

.wrapper{max-width:900px;margin:0 auto;padding:0 24px 100px;position:relative;z-index:1}

/* HEADER */
.site-header{display:flex;align-items:center;justify-content:space-between;padding:20px 0;border-bottom:1px solid var(--border);margin-bottom:44px;animation:fadeDown .6s ease both;flex-wrap:wrap;gap:12px}
.logo-area{display:flex;align-items:center;gap:14px}
.logo-img{width:48px;height:48px;border-radius:10px;background:var(--accent-dim);border:1px solid rgba(52,216,126,.25);display:flex;align-items:center;justify-content:center;overflow:hidden}
.logo-img img{width:100%;height:100%;object-fit:contain}
.logo-ph{font-family:'DM Serif Display',serif;font-size:22px;color:var(--accent)}
.logo-text{display:flex;flex-direction:column}
.logo-name{font-family:'DM Serif Display',serif;font-size:20px;color:var(--text);letter-spacing:.1em;text-transform:uppercase}
.logo-sub{font-family:'DM Mono',monospace;font-size:9px;color:var(--accent);letter-spacing:.2em;text-transform:uppercase;margin-top:2px}
.header-badge{display:flex;align-items:center;gap:8px;background:var(--gold-dim);border:1px solid rgba(212,169,66,.3);border-radius:6px;padding:8px 14px}
.badge-text{font-family:'DM Mono',monospace;font-size:10px;color:var(--gold);letter-spacing:.08em;text-transform:uppercase;line-height:1.5}

/* CONTROLS */
.controls-bar{display:flex;align-items:center;gap:16px;margin-bottom:28px;animation:fadeUp .7s ease .05s both;flex-wrap:wrap;padding:14px 20px;background:var(--surface);border:1px solid var(--border);border-radius:10px}
.ctrl-group{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.ctrl-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
.ctrl-divider{width:1px;height:26px;background:var(--border2)}
.ctrl-btn{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.05em;padding:6px 13px;border-radius:5px;border:1px solid var(--border2);background:var(--surface3);color:var(--muted);cursor:pointer;transition:all .2s}
.ctrl-btn:hover{border-color:var(--accent);color:var(--accent2)}
.ctrl-btn.active{background:var(--accent-dim);border-color:rgba(52,216,126,.5);color:var(--accent)}

/* HERO */
header{margin-bottom:44px;animation:fadeUp .7s ease both}
.tag{display:inline-flex;align-items:center;gap:8px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);border:1px solid rgba(52,216,126,.3);padding:5px 14px;border-radius:3px;margin-bottom:20px;opacity:.85;background:var(--accent-dim)}
.tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 2s ease infinite}
h1{font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.4rem);font-weight:400;line-height:1.12;color:var(--text);margin-bottom:16px}
h1 span{color:var(--accent)}
.subtitle{color:var(--muted);font-size:1rem;line-height:1.8;max-width:600px}
.subtitle strong{color:var(--accent2);font-weight:400}

/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:32px;margin-bottom:24px;animation:fadeUp .7s ease both;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(52,216,126,.2),transparent)}
.card-title{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:24px}

.input-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:580px){.input-grid{grid-template-columns:1fr}}
.field{display:flex;flex-direction:column;gap:8px}
.field label{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace;letter-spacing:.05em}
body[lang="ar"] .field label{font-family:'Noto Sans Arabic',sans-serif;letter-spacing:0;text-align:right;font-size:13px}
.field input{background:var(--surface3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Outfit',sans-serif;font-size:15px;padding:12px 16px;outline:none;transition:border-color .2s,box-shadow .2s}
.field input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(52,216,126,.07)}
.field input::placeholder{color:var(--muted);opacity:.4}
.slider-wrap{display:flex;flex-direction:column;gap:8px}
.slider-row{display:flex;align-items:center;gap:12px}
input[type=range]{flex:1;-webkit-appearance:none;height:4px;background:var(--border2);border-radius:2px;outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--accent);cursor:pointer;border:3px solid var(--bg);box-shadow:0 0 0 1px var(--accent)}
.slider-val{font-family:'DM Mono',monospace;font-size:13px;color:var(--accent);min-width:28px;text-align:right}

/* BUTTONS */
.btn-row{display:flex;gap:14px;margin-top:28px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:10px;background:var(--accent);color:#060e08;border:none;border-radius:8px;font-family:'Outfit',sans-serif;font-size:14px;font-weight:600;padding:14px 28px;cursor:pointer;transition:background .2s,transform .1s,box-shadow .2s;letter-spacing:.02em}
body[lang="ar"] .btn{font-family:'Noto Sans Arabic',sans-serif}
.btn:hover{background:var(--accent2);box-shadow:0 0 24px rgba(52,216,126,.25)}
.btn:active{transform:scale(.98)}
.btn svg{width:17px;height:17px;flex-shrink:0}
.btn-sec{background:transparent;color:var(--accent);border:1px solid rgba(52,216,126,.4)}
.btn-sec:hover{background:var(--accent-dim);box-shadow:none}

/* RESULTS */
#results{display:none;animation:fadeUp .5s ease both}
.results-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:28px}
@media(max-width:560px){.results-grid{grid-template-columns:1fr}}
.result-box{background:var(--surface3);border:1px solid var(--border);border-radius:12px;padding:22px 24px;position:relative;overflow:hidden}
.result-box.green{border-color:rgba(52,216,126,.2)}
.result-box.yellow{border-color:rgba(245,197,66,.2)}
.result-box.blue{border-color:rgba(96,165,250,.2)}
.result-box.redd{border-color:rgba(248,113,113,.2)}
.result-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.result-box.green::before{background:linear-gradient(90deg,var(--accent),transparent)}
.result-box.yellow::before{background:linear-gradient(90deg,var(--warn),transparent)}
.result-box.blue::before{background:linear-gradient(90deg,var(--blue),transparent)}
.result-box.redd::before{background:linear-gradient(90deg,var(--red),transparent)}
.result-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
.result-value{font-family:'DM Serif Display',serif;font-size:clamp(1.5rem,4vw,2.1rem);font-weight:400;line-height:1;margin-bottom:4px}
.result-box.green .result-value{color:var(--accent)}
.result-box.yellow .result-value{color:var(--warn)}
.result-box.blue .result-value{color:#93c5fd}
.result-box.redd .result-value{color:var(--red)}
.result-sub{font-size:11px;color:var(--muted)}

.breakdown{border-top:1px solid var(--border);padding-top:24px;margin-top:4px}
.breakdown-title{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.breakdown-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(26,46,31,.7);font-size:14px}
.breakdown-row:last-child{border-bottom:none}
.breakdown-row .lbl{color:var(--muted)}
.breakdown-row .val{font-family:'DM Mono',monospace;font-size:13px;color:var(--text)}
.breakdown-row .val.pos{color:var(--accent)}
.breakdown-row .val.neg{color:var(--red)}
.breakdown-row .val.neutral{color:var(--warn)}

.bar-section{margin-top:24px;padding-top:24px;border-top:1px solid var(--border)}
.bar-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}
.bar-item{margin-bottom:16px}
.bar-meta{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:8px}
.bar-track{height:8px;background:var(--border);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;width:0;transition:width 1.2s cubic-bezier(.16,1,.3,1)}
.bar-fill.green{background:linear-gradient(90deg,var(--accent),var(--accent2))}
.bar-fill.warn{background:linear-gradient(90deg,var(--warn),#fde68a)}
.bar-fill.red{background:linear-gradient(90deg,var(--red),#fca5a5)}
.bar-fill.blue{background:linear-gradient(90deg,var(--blue),#93c5fd)}

/* FOOTER */
.site-footer{margin-top:60px;padding-top:26px;border-top:1px solid var(--border)}
.footer-top{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:14px;margin-bottom:16px}
.footer-brand{font-family:'DM Serif Display',serif;font-size:15px;color:var(--muted2);letter-spacing:.1em;text-transform:uppercase}
.footer-itex{display:flex;align-items:center;gap:8px;background:var(--gold-dim);border:1px solid rgba(212,169,66,.25);border-radius:5px;padding:6px 14px}
.footer-itex span{font-family:'DM Mono',monospace;font-size:10px;color:var(--gold);letter-spacing:.06em}
.footer-bottom{display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
.footer-bottom span{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.05em;opacity:.7}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-14px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* ════════════════ PRINT/PDF ════════════════ */
@media print{
  @page{size:A4 portrait;margin:14mm 16mm}
  body>*{display:none!important}
  #pdf-shell{display:block!important}
  #pdf-shell *{-webkit-print-color-adjust:exact;print-color-adjust:exact}
}

#pdf-shell{display:none;font-family:'Outfit',sans-serif;color:#0d1f10;background:#fff;width:100%}

/* report layout */
.rpt{width:100%;background:#fff;color:#0d1f10}
.rpt-hdr{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid #34d87e;padding-bottom:16px;margin-bottom:20px}
.rpt-brand-name{font-family:'DM Serif Display',serif;font-size:26px;color:#0a1a0d;letter-spacing:.1em;text-transform:uppercase}
.rpt-brand-sub{font-family:'DM Mono',monospace;font-size:9px;color:#34d87e;letter-spacing:.2em;text-transform:uppercase;margin-top:3px}
.rpt-badge-side{text-align:right}
.rpt-medal{font-size:24px}
.rpt-badge-txt{font-family:'DM Mono',monospace;font-size:9px;color:#b8860b;text-transform:uppercase;letter-spacing:.08em;line-height:1.6;margin-top:3px}
.rpt-title{font-family:'DM Serif Display',serif;font-size:18px;color:#0d1f10;margin-bottom:3px}
.rpt-sub{font-family:'DM Mono',monospace;font-size:10px;color:#5a7a60;letter-spacing:.05em;margin-bottom:18px}
.rpt-meta{display:flex;gap:18px;flex-wrap:wrap;padding:11px 15px;background:#f0faf3;border-radius:7px;border:1px solid #c8e8d0;margin-bottom:20px}
.rpt-mi{display:flex;flex-direction:column;gap:2px}
.rpt-ml{font-family:'DM Mono',monospace;font-size:8px;color:#5a8068;text-transform:uppercase;letter-spacing:.1em}
.rpt-mv{font-size:12px;color:#0d1f10;font-weight:600}
.rpt-sec{font-family:'DM Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:#34d87e;margin-bottom:9px;padding-bottom:5px;border-bottom:1px solid #dceee2;margin-top:2px}
.rpt-kpi-row{display:flex;gap:12px;margin-bottom:20px}
.rpt-kpi{flex:1;padding:13px;border:2px solid #c8e8d0;border-radius:7px;text-align:center}
.rpt-kpi-lbl{font-family:'DM Mono',monospace;font-size:8px;text-transform:uppercase;letter-spacing:.1em;color:#5a8068;margin-bottom:5px}
.rpt-kpi-val{font-family:'DM Serif Display',serif;font-size:20px;color:#1a8a4a}
.rpt-kpi-unit{font-size:9px;color:#5a8068;margin-top:2px}
.rpt-tbl{width:100%;border-collapse:collapse;margin-bottom:18px;font-size:11px}
.rpt-tbl th{text-align:left;padding:7px 10px;background:#0d1f10;color:#34d87e;font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.1em;text-transform:uppercase;font-weight:500}
.rpt-tbl td{padding:7px 10px;border-bottom:1px solid #e4f0e8;color:#0d1f10}
.rpt-tbl tr:nth-child(even) td{background:#f7fbf8}
.rpt-tbl .hl{color:#1a8a4a;font-weight:600}
.rpt-ftr{margin-top:24px;padding-top:12px;border-top:2px solid #c8e8d0;display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px}
.rpt-ftr span{font-family:'DM Mono',monospace;font-size:8px;color:#5a8068;letter-spacing:.05em}
</style>
</head>
<body lang="en">

<!-- ═══════════ SCREEN ═══════════ -->
<div class="wrapper">

  <div class="site-header">
    <div class="logo-area">
      <div class="logo-img">
        <img src="Ecora.png" alt="Ecora"
          onerror="this.style.display='none';this.parentNode.innerHTML='<span class=\'logo-ph\'>E</span>'"/>
      </div>
      <div class="logo-text">
        <span class="logo-name">Ecora Matrix</span>
        <span class="logo-sub">Impact &amp; ROI Calculator</span>
      </div>
    </div>
    <div class="header-badge">
      <span>🥇</span>
      <div class="badge-text" id="hdr-badge">Gold Medalist<br>SIIF 2025</div>
    </div>
  </div>

  <div class="controls-bar">
    <div class="ctrl-group">
      <span class="ctrl-label" id="lbl-cur">Currency</span>
      <button class="ctrl-btn active" onclick="setCur('USD')" id="btn-USD">$ USD</button>
      <button class="ctrl-btn" onclick="setCur('MYR')" id="btn-MYR">RM MYR</button>
      <button class="ctrl-btn" onclick="setCur('SAR')" id="btn-SAR">SR SAR</button>
    </div>
    <div class="ctrl-divider"></div>
    <div class="ctrl-group">
      <span class="ctrl-label" id="lbl-lang">Language</span>
      <button class="ctrl-btn active" onclick="setLang('en')" id="lang-en">EN</button>
      <button class="ctrl-btn" onclick="setLang('ar')" id="lang-ar">عربي</button>
      <button class="ctrl-btn" onclick="setLang('ms')" id="lang-ms">BM</button>
    </div>
  </div>

  <header>
    <div class="tag" id="hero-tag">Photocatalytic PET Recycling · Research Tool</div>
    <h1 id="hero-h1">PET Upcycling<br><span>Impact Calculator</span></h1>
    <p class="subtitle" id="hero-sub">Based on <strong>selective photocatalytic recycling of PET plastic</strong> using Brookite TiO₂/rGO catalyst under visible sunlight. Enter your facility data to estimate economic returns and environmental impact.</p>
  </header>

  <div class="card">
    <div class="card-title" id="lbl-card-in">// Facility Input Parameters</div>
    <div class="input-grid">
      <div class="field"><label id="lbl-pet">PET Waste Input (tons / year)</label><input type="number" id="petTons" value="500" min="1"/></div>
      <div class="field"><label id="lbl-days">Operational Days / Year</label><input type="number" id="opDays" value="300" min="1" max="365"/></div>
      <div class="field slider-wrap">
        <label id="lbl-ph">Solution pH (2 = optimal yield)</label>
        <div class="slider-row">
          <input type="range" id="phSlider" min="1" max="4" step="0.5" value="2" oninput="document.getElementById('phVal').textContent=this.value"/>
          <span class="slider-val" id="phVal">2</span>
        </div>
      </div>
      <div class="field"><label id="lbl-acp">Market Price — Acetic Acid (USD/ton)</label><input type="number" id="aceticP" value="600" min="1"/></div>
      <div class="field"><label id="lbl-fcp">Market Price — Formic Acid (USD/ton)</label><input type="number" id="formicP" value="700" min="1"/></div>
      <div class="field"><label id="lbl-opc">Operational Cost (USD/ton PET)</label><input type="number" id="opCost" value="80" min="0"/></div>
    </div>
    <div class="btn-row">
      <button class="btn" onclick="calculate()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <span id="btn-calc">Calculate Impact</span>
      </button>
    </div>
  </div>

  <div id="results">
    <div class="card">
      <div class="card-title" id="lbl-card-out">// Environmental &amp; Economic Output</div>
      <div class="results-grid">
        <div class="result-box green"><div class="result-label" id="rl-acids">Organic Acids Produced</div><div class="result-value" id="r-acids">—</div><div class="result-sub" id="rs-acids">tons / year</div></div>
        <div class="result-box yellow"><div class="result-label" id="rl-rev">Gross Revenue</div><div class="result-value" id="r-rev">—</div><div class="result-sub" id="rs-rev">/ year</div></div>
        <div class="result-box blue"><div class="result-label" id="rl-profit">Net Profit</div><div class="result-value" id="r-profit">—</div><div class="result-sub" id="rs-profit">/ year</div></div>
        <div class="result-box redd"><div class="result-label" id="rl-co2">CO₂ Avoided vs Incineration</div><div class="result-value" id="r-co2">—</div><div class="result-sub" id="rs-co2">tons CO₂ / year</div></div>
      </div>

      <div class="breakdown">
        <div class="breakdown-title" id="lbl-bk">// Detailed Breakdown</div>
        <div class="breakdown-row"><span class="lbl" id="bk1">Acetic Acid Produced</span><span class="val pos" id="v-ac">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk2">Formic Acid Produced</span><span class="val pos" id="v-fo">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk3">Acetic Acid Revenue</span><span class="val pos" id="v-acr">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk4">Formic Acid Revenue</span><span class="val pos" id="v-for">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk5">Total Operational Cost</span><span class="val neg" id="v-cost">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk6">Gross Margin</span><span class="val neutral" id="v-mgn">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk7">CO₂ Emitted (this system)</span><span class="val neutral" id="v-emit">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk8">CO₂ if Incinerated</span><span class="val neg" id="v-inc">—</span></div>
        <div class="breakdown-row"><span class="lbl" id="bk9">Carbon Stored in Acids</span><span class="val pos" id="v-carb">—</span></div>
      </div>

