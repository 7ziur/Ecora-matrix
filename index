/* ════ STATE ════ */
const CURR={USD:{s:'$',l:'USD',r:1},MYR:{s:'RM ',l:'MYR',r:4.71},SAR:{s:'SR ',l:'SAR',r:3.75}};
let cur='USD',lang='en',C={};

/* ════ CURRENCY ════ */
function setCur(c){
  cur=c;
  document.querySelectorAll('[id^="btn-USD"],[id="btn-MYR"],[id="btn-SAR"]').forEach(b=>b.classList.remove('active'));
  document.getElementById('btn-'+c).classList.add('active');
  if(document.getElementById('results').style.display!=='none') calculate();
}

/* ════ LANGUAGE ════ */
function setLang(l){
  lang=l;
  document.querySelectorAll('[id^="lang-"]').forEach(b=>b.classList.remove('active'));
  document.getElementById('lang-'+l).classList.add('active');
  document.body.setAttribute('lang',l);
  document.body.setAttribute('dir',l==='ar'?'rtl':'ltr');
  const t=T[l];
  const s=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v};
  const si=(id,v)=>{const el=document.getElementById(id);if(el)el.innerHTML=v};
  si('hero-h1',t.h1); si('hero-sub',t.sub); si('hdr-badge',t.badge);
  si('ftx',t.ftx);
  s('hero-tag',t.heroTag); s('lbl-card-in',t.cardIn); s('lbl-card-out',t.cardOut);
  s('lbl-cur',t.lCur); s('lbl-lang',t.lLang);
  s('lbl-pet',t.lPet); s('lbl-days',t.lDays); s('lbl-ph',t.lPh);
  s('lbl-acp',t.lAcp); s('lbl-fcp',t.lFcp); s('lbl-opc',t.lOpc);
  s('btn-calc',t.bCalc); s('btn-pdf',t.bPdf);
  s('rl-acids',t.rlAcids); s('rl-rev',t.rlRev); s('rl-profit',t.rlProfit); s('rl-co2',t.rlCo2);
  s('rs-acids',t.rsAcids); s('rs-co2',t.rsCo2);
  s('lbl-bk',t.bkT); s('lbl-bar',t.barT);
  s('finv',t.finv);
  t.bk.forEach((v,i)=>s('bk'+(i+1),v));
  t.bars.forEach((v,i)=>s('bar'+(i+1),v));
  if(document.getElementById('results').style.display!=='none') calculate();
}

/* ════ HELPERS ════ */
function phY(ph){return({1:.65,1.5:.85,2:1,2.5:.75,3:.55,3.5:.38,4:.25}[ph])||1}
function fmt(n,d=0){return n.toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d})}
function fmtM(n){const c=CURR[cur];return c.s+fmt(n*c.r)}

/* ════ CALCULATE ════ */
function calculate(){
  const pet=parseFloat(document.getElementById('petTons').value)||0;
  const ph=parseFloat(document.getElementById('phSlider').value);
  const ap=parseFloat(document.getElementById('aceticP').value)||600;
  const fp=parseFloat(document.getElementById('formicP').value)||700;
  const oc=parseFloat(document.getElementById('opCost').value)||80;
  if(pet<=0){alert(T[lang].aPet);return}

  const yf=phY(ph);
  const ta=pet*.241*yf,ac=ta*.78,fo=ta*.22;
  const ar=ac*ap,fr=fo*fp,rev=ar+fr;
  const cost=pet*oc,np=rev-cost,mgn=rev>0?np/rev*100:0;
  const emit=pet*.1,cinc=pet*2.293,cavo=cinc-emit,carb=ac*.4+fo*.261;

  C={pet,ph,ta,ac,fo,ar,fr,rev,cost,np,mgn,emit,cinc,cavo,carb};
  const c=CURR[cur];

  const s=(id,v)=>document.getElementById(id).textContent=v;
  s('r-acids',fmt(ta,1)+' t');
  s('r-rev',fmtM(rev));
  s('rs-rev',c.l+' / year');
  s('r-profit',(np>=0?'+':'')+fmtM(np));
  s('rs-profit',c.l+' / year');
  s('r-co2',fmt(cavo)+' t');
  s('v-ac',fmt(ac,2)+' t');
  s('v-fo',fmt(fo,2)+' t');
  s('v-acr','+ '+fmtM(ar));
  s('v-for','+ '+fmtM(fr));
  s('v-cost','− '+fmtM(cost));
  s('v-mgn',fmt(mgn,1)+'%');
  s('v-emit',fmt(emit,1)+' t CO₂');
  s('v-inc',fmt(cinc,1)+' t CO₂');
  s('v-carb',fmt(carb,2)+' t C');

  document.getElementById('results').style.display='block';
  setTimeout(()=>{
    document.getElementById('bfill1').style.width='100%';
    document.getElementById('bfill2').style.width=(1600/2293*100)+'%';
    document.getElementById('bfill3').style.width=(400/2293*100)+'%';
    document.getElementById('bfill4').style.width=(100/2293*100)+'%';
  },100);
  document.getElementById('results').scrollIntoView({behavior:'smooth',block:'start'});
}

/* ════ PDF via window.print() ════ */
function generatePDF(){
  if(!C.pet){alert(T[lang].aCalc);return}
  const c=CURR[cur];
  const now=new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  const s=(id,v)=>document.getElementById(id).textContent=v;

  s('rpt-date','Generated: '+now);
  s('rpt-fdate',now);
  s('rpt-pet',fmt(C.pet)+' tons / year');
  s('rpt-ph',C.ph);
  s('rpt-cur',c.l);
  s('rpt-kpi-pet',fmt(C.pet));
  s('rpt-kpi-profit',c.s+fmt(C.np*c.r));
  s('rpt-kpi-pu',c.l+' / year');
  s('rpt-kpi-co2',fmt(C.cavo));
  s('rpt-ac',fmt(C.ac,2));
  s('rpt-fo',fmt(C.fo,2));
  s('rpt-acr',c.s+fmt(C.ar*c.r));
  s('rpt-for',c.s+fmt(C.fr*c.r));
  s('rpt-grev',c.s+fmt(C.rev*c.r));
  s('rpt-cost',c.s+fmt(C.cost*c.r));
  s('rpt-net',(C.np>=0?'+':'')+c.s+fmt(C.np*c.r));
  s('rpt-mgn',fmt(C.mgn,1));
  s('rpt-emit',fmt(C.emit,1));
  s('rpt-cinc',fmt(C.cinc,1));
  s('rpt-cavo',fmt(C.cavo,1));
  s('rpt-carb',fmt(C.carb,2));

  const btn=document.getElementById('btn-pdf');
  const orig=btn.textContent;
  btn.textContent=T[lang].bPrinting;
  /* small delay ensures DOM paints before print dialog opens */
  setTimeout(()=>{window.print();btn.textContent=orig;},250);
}
